ARG KYLIN_BASE_IMAGE=macrosan/kylin:v10-sp3-2403
FROM ${KYLIN_BASE_IMAGE}

LABEL name="gpt-vis-mcp"
LABEL description="GPT-Vis MCP Server - SSR Mode - Kylin ARM64 build"

ARG DENO_VERSION=2.3.6

RUN yum update -y && yum install -y \
    gcc \
    gcc-c++ \
    make \
    cairo-devel \
    pango-devel \
    libjpeg-devel \
    giflib-devel \
    librsvg2-devel \
    pkgconfig \
    python3 \
    python3-pip \
    curl \
    unzip \
    glibc-langpack-en \
    glibc-langpack-zh \
    fontconfig \
    google-noto-sans-cjk-fonts \
    && yum clean all

RUN curl -fsSL https://rpm.nodesource.com/setup_lts.x | bash - \
    && yum install -y nodejs \
    && npm install -g node-gyp \
    && yum clean all

RUN curl -fsSL "https://github.com/denoland/deno/releases/download/v${DENO_VERSION}/deno-aarch64-unknown-linux-gnu.zip" -o /tmp/deno.zip \
    && unzip /tmp/deno.zip -d /usr/local/bin \
    && chmod +x /usr/local/bin/deno \
    && rm -f /tmp/deno.zip

WORKDIR /app

COPY deno.json deno.lock* ./

ENV RENDERED_IMAGE_PATH=/tmp/gpt-vis-charts \
    DENO_DIR=/deno-dir \
    DENO_INSTALL_ROOT=/deno-dir/install-root \
    LANG=zh_CN.UTF-8 \
    LANGUAGE=zh_CN:zh \
    LC_ALL=zh_CN.UTF-8 \
    MODE=http \
    PORT=3000

RUN mkdir -p $DENO_DIR $RENDERED_IMAGE_PATH

COPY . .

RUN deno task compile && \
    deno cache stdio.server.ts

EXPOSE 3000

CMD ["deno", "run", "--cached-only", "--allow-all", "ssr.server.ts"]
