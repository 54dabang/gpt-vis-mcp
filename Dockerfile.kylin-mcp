ARG KYLIN_BASE_IMAGE=macrosan/kylin:v10-sp3-2403
FROM ${KYLIN_BASE_IMAGE}

LABEL name="gpt-vis-mcp"
LABEL description="GPT-Vis MCP Server - MCP Mode - Kylin ARM64 build"

ARG DENO_VERSION=2.3.6
ARG NODE_VERSION=22.21.1
ARG PIXMAN_VERSION=0.43.4
ARG CAIRO_VERSION=1.16.0

ENV PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/local/lib64/pkgconfig:/usr/lib64/pkgconfig \
    LD_LIBRARY_PATH=/usr/local/lib:/usr/local/lib64 \
    LDFLAGS="-Wl,-z,max-page-size=65536" \
    npm_config_build_from_source=true \
    npm_config_canvas_build_from_source=true \
    npm_config_foreground_scripts=true

RUN yum update -y && yum install -y \
    autoconf \
    automake \
    binutils \
    libtool \
    gcc \
    gcc-c++ \
    make \
    xz \
    tar \
    zlib-devel \
    libpng-devel \
    freetype-devel \
    fontconfig-devel \
    expat-devel \
    pango-devel \
    libjpeg-devel \
    giflib-devel \
    librsvg2-devel \
    pkgconfig \
    python3 \
    python3-pip \
    curl \
    unzip \
    glibc-langpack-en \
    glibc-langpack-zh \
    fontconfig \
    && yum clean all

RUN python3 -m pip install --no-cache-dir meson ninja

RUN curl -fsSL "https://www.cairographics.org/releases/pixman-${PIXMAN_VERSION}.tar.gz" -o /tmp/pixman.tar.gz \
    && mkdir -p /tmp/pixman \
    && tar -xzf /tmp/pixman.tar.gz -C /tmp/pixman --strip-components=1 \
    && cd /tmp/pixman \
    && meson setup build --prefix=/usr/local --libdir=lib -Ddefault_library=shared \
    && meson compile -C build -j"$(nproc)" \
    && meson install -C build \
    && rm -rf /tmp/pixman /tmp/pixman.tar.gz \
    && ldconfig

RUN curl -fsSL "https://www.cairographics.org/releases/cairo-${CAIRO_VERSION}.tar.xz" -o /tmp/cairo.tar.xz \
    && mkdir -p /tmp/cairo \
    && tar -xJf /tmp/cairo.tar.xz -C /tmp/cairo --strip-components=1 \
    && cd /tmp/cairo \
    && ./configure --prefix=/usr/local --libdir=/usr/local/lib --disable-static --enable-ft --enable-fc --enable-png --disable-xlib --disable-xcb --disable-gtk-doc \
    && make -j"$(nproc)" \
    && make install \
    && rm -rf /tmp/cairo /tmp/cairo.tar.xz \
    && ldconfig \
    && readelf -l /usr/local/lib/libpixman-1.so.0 | grep LOAD \
    && readelf -l /usr/local/lib/libcairo.so.2 | grep LOAD

RUN curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-arm64.tar.xz" -o /tmp/node.tar.xz \
    && tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 \
    && rm -f /tmp/node.tar.xz \
    && node --version \
    && npm --version \
    && npm install -g node-gyp

RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    /root/.local/bin/uv tool install mcp-proxy

RUN curl -fsSL "https://github.com/denoland/deno/releases/download/v${DENO_VERSION}/deno-aarch64-unknown-linux-gnu.zip" -o /tmp/deno.zip \
    && unzip /tmp/deno.zip -d /usr/local/bin \
    && chmod +x /usr/local/bin/deno \
    && rm -f /tmp/deno.zip

WORKDIR /app

COPY deno.json deno.lock* ./

ENV RENDERED_IMAGE_PATH=/tmp/gpt-vis-charts \
    DENO_DIR=/deno-dir \
    DENO_INSTALL_ROOT=/deno-dir/install-root \
    DENO_CACHED_ONLY=true \
    LANG=zh_CN.UTF-8 \
    LANGUAGE=zh_CN:zh \
    LC_ALL=zh_CN.UTF-8 \
    PATH="/root/.local/bin:$PATH"

RUN mkdir -p $DENO_DIR $RENDERED_IMAGE_PATH

COPY . .

RUN deno task compile && \
    deno cache --allow-scripts=npm:canvas@3.2.0 server.ts && \
    deno cache --allow-scripts=npm:canvas@3.2.0 stdio.server.ts && \
    deno cache --allow-scripts=npm:canvas@3.2.0 app.ts && \
    deno eval --allow-all "const canvas = await import('npm:canvas@3.2.0'); const createCanvas = canvas.createCanvas ?? canvas.default.createCanvas; createCanvas(1, 1).getContext('2d').fillRect(0, 0, 1, 1)"

ENTRYPOINT ["deno", "run", "--cached-only", "--allow-all", "server.ts"]
CMD ["--transport", "stdio"]
